rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return isSignedIn() && 
             request.auth.token.email in ['perseus@tecsonmedia.com', 'ptecsonmedia@gmail.com', 'perseusgaming24@gmail.com', 'zainnast225@gmail.com'] && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidBooking(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'websiteType', 'budget', 'description', 'status', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 9 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.websiteType is string && data.websiteType.size() > 0 && data.websiteType.size() <= 100 &&
             data.budget is string && data.budget.size() > 0 && data.budget.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 5000 &&
             data.status in ['pending', 'confirmed', 'organized'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // --- Collections ---

    match /bookings/{bookingId} {
      // 3. Path Variable Hardening
      allow get: if isVerifiedAdmin() && isValidId(bookingId);
      
      // 8. Secure List Queries
      allow list: if isVerifiedAdmin();

      allow create: if 
        isValidId(bookingId) && 
        isValidBooking(incoming()) &&
        incoming().status == 'pending' &&
        incoming().createdAt == request.time &&
        incoming().updatedAt == request.time;

      allow update: if 
        isVerifiedAdmin() && 
        isValidBooking(incoming()) && (
          // Action: Confirm or Organize
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
           incoming().updatedAt == request.time &&
           incoming().status in ['confirmed', 'organized'])
        );

      allow delete: if isVerifiedAdmin();
    }
  }
}
