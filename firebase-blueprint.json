{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Information about a client project inquiry.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the client." },
        "email": { "type": "string", "format": "email", "description": "Email address of the client." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "websiteType": { "type": "string", "description": "The type of website requested." },
        "budget": { "type": "string", "description": "The estimated project budget." },
        "description": { "type": "string", "description": "Project details provided by the client." },
        "status": { 
          "type": "string", 
          "enum": ["pending", "confirmed", "organized"],
          "description": "Current status of the booking inquiry."
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the booking was last updated." }
      },
      "required": ["name", "email", "websiteType", "budget", "description", "status", "createdAt"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of project inquiries."
    }
  }
}
